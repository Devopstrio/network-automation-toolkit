# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="Network Automation Toolkit"

# Security
SECRET_KEY=networkautomationtoolkitsecret123
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Network Credentials (Simulation)
NETWORK_USER=admin
NETWORK_PASSWORD=password123
SSH_KEY_PATH=/root/.ssh/id_rsa

# Database
POSTGRES_SERVER=localhost
